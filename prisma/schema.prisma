generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  phone_number     String      @unique
  password_hash    String
  role             Role        @default(CUSTOMER)
  points_balance   Int         @default(0)
  qr_token         String      @unique @default(dbgenerated("(gen_random_uuid())::text"))
  otp_enabled      Boolean     @default(false)
  created_at       DateTime    @default(now()) @db.Timestamptz(6)
  updated_at       DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  orders           Order[]
  performedLogs    PointsLog[] @relation("StaffPerformed")
  pointsLogs       PointsLog[] @relation("UserPoints")
  sessions         Session[]
  redeemedVouchers Voucher[]   @relation("StaffRedeemed")
  vouchers         Voucher[]   @relation("UserVouchers")

  @@map("users")
}

model Session {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String   @db.Uuid
  refresh_token String   @unique @default(dbgenerated("(gen_random_uuid())::text"))
  expires_at    DateTime @db.Timestamptz(6)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([refresh_token], map: "idx_sessions_refresh_token")
  @@index([user_id], map: "idx_sessions_user_id")
  @@map("sessions")
}

model OtpAttempt {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone_number String
  code_hash    String
  expires_at   DateTime @db.Timestamptz(6)
  attempts     Int      @default(0)
  verified     Boolean  @default(false)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@index([phone_number], map: "idx_otp_attempts_phone")
  @@map("otp_attempts")
}

model VoucherPackage {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  description        String?
  voucher_type       VoucherType
  points_cost        Int
  discount_type      DiscountType?
  discount_value     Int?
  menu_item_id       String?       @db.Uuid
  is_active          Boolean       @default(true)
  expires_after_days Int?
  created_at         DateTime      @default(now()) @db.Timestamptz(6)
  menuItem           MenuItem?     @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vouchers           Voucher[]

  @@map("voucher_packages")
}

model Voucher {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String         @db.Uuid
  package_id     String         @db.Uuid
  qr_token       String         @unique @default(dbgenerated("(gen_random_uuid())::text"))
  voucher_type   VoucherType
  discount_type  DiscountType?
  discount_value Int?
  menu_item_id   String?        @db.Uuid
  status         VoucherStatus  @default(ACTIVE)
  used_channel   UsedChannel?
  expires_at     DateTime?      @db.Timestamptz(6)
  redeemed_at    DateTime?      @db.Timestamptz(6)
  redeemed_by    String?        @db.Uuid
  created_at     DateTime       @default(now()) @db.Timestamptz(6)
  orderItems     OrderItem[]
  orders         Order[]
  pointsLogs     PointsLog[]
  menuItem       MenuItem?      @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  package        VoucherPackage @relation(fields: [package_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff          User?          @relation("StaffRedeemed", fields: [redeemed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User           @relation("UserVouchers", fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([qr_token], map: "idx_vouchers_qr_token")
  @@index([status], map: "idx_vouchers_status")
  @@index([user_id], map: "idx_vouchers_user_id")
  @@map("vouchers")
}

model PointsLog {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String      @db.Uuid
  delta           Int
  reason          String
  performed_by    String?     @db.Uuid
  reversed_log_id String?     @db.Uuid
  order_id        String?     @db.Uuid
  voucher_id      String?     @db.Uuid
  created_at      DateTime    @default(now()) @db.Timestamptz(6)
  order           Order?      @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  staff           User?       @relation("StaffPerformed", fields: [performed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversedLog     PointsLog?  @relation("Reversal", fields: [reversed_log_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reversalLogs    PointsLog[] @relation("Reversal")
  user            User        @relation("UserPoints", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  voucher         Voucher?    @relation(fields: [voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_points_log_created_at")
  @@index([user_id], map: "idx_points_log_user_id")
  @@map("points_log")
}

model Promotion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String
  description     String?
  starts_at       DateTime @db.Timestamptz(6)
  ends_at         DateTime @db.Timestamptz(6)
  max_redemptions Int
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  @@map("promotions")
}

model MenuItem {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  description          String?
  category             String
  image_url            String?
  is_available         Boolean               @default(true)
  sort_order           Int                   @default(0)
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  is_seasonal          Boolean               @default(false)
  matcha_powder_id     String?               @db.Uuid
  default_powder_id    String?               @db.Uuid
  custom_powder_grams  Json?
  base_liquid_note     String?
  updated_at           DateTime              @default(now()) @db.Timestamptz(6)
  fusionAllowedPowders FusionAllowedPowder[]
  /// Powder that references this Latte item as its pricing anchor
  referenceLatteItem   MatchaPowder?         @relation("MatchaPowder_referenceLatteItem")
  sizes                MenuItemSize[]
  defaultPowder        MatchaPowder?         @relation("MenuItem_defaultPowder", fields: [default_powder_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  matchaPowder         MatchaPowder?         @relation("MenuItem_matchaPowder", fields: [matcha_powder_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderItems           OrderItem[]
  voucherPackages      VoucherPackage[]
  vouchers             Voucher[]

  @@index([category], map: "idx_menu_items_category")
  @@index([is_available], map: "idx_menu_items_is_available")
  @@map("menu_items")
}

model AddonGroup {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  description  String?
  type         AddonType
  is_required  Boolean
  min_quantity Int?
  max_quantity Int?
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  is_active    Boolean       @default(true)
  options      AddonOption[]

  @@map("addon_groups")
}

model AddonOption {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  addon_group_id String           @db.Uuid
  label          String
  price_vnd      Int              @default(0)
  is_default     Boolean          @default(false)
  sort_order     Int              @default(0)
  /// gram amount for extra matcha options; null for all other addon types
  gram_value     Decimal?         @db.Decimal
  group          AddonGroup       @relation(fields: [addon_group_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orderItemAddons OrderItemAddon[]

  @@map("addon_options")
}

model MenuItemSize {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menu_item_id   String   @db.Uuid
  size           Size
  /// null = this size is not sold; hidden from UI entirely
  base_price_vnd Int?
  menuItem       MenuItem @relation(fields: [menu_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([menu_item_id, size])
  @@index([menu_item_id], map: "idx_menu_item_sizes_menu_item_id")
  @@map("menu_item_sizes")
}

model Order {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String      @db.Uuid
  voucher_id    String?     @db.Uuid
  status        OrderStatus @default(PENDING)
  subtotal_vnd  Int
  discount_vnd  Int         @default(0)
  total_vnd     Int
  points_earned Int?
  pickup_time   DateTime?   @db.Timestamptz(6)
  note          String?
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  items         OrderItem[]
  user          User        @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  voucher       Voucher?    @relation(fields: [voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pointsLogs    PointsLog[]

  @@index([created_at(sort: Desc)], map: "idx_orders_created_at")
  @@index([status], map: "idx_orders_status")
  @@index([user_id], map: "idx_orders_user_id")
  @@map("orders")
}

model OrderItem {
  id                    String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id              String           @db.Uuid
  menu_item_id          String           @db.Uuid
  quantity              Int
  unit_price_vnd        Int
  addons_price_vnd      Int              @default(0)
  product_voucher_id    String?          @db.Uuid
  note                  String?
  sweetness             SweetnessLevel   @default(QUARTER)
  size                  Size
  selected_powder_id    String?          @db.Uuid
  selected_milk_type_id String?          @db.Uuid
  ice_option            IceOption        @default(NORMAL)
  coldwhisk             Boolean          @default(false)
  addons                OrderItemAddon[]
  menuItem              MenuItem         @relation(fields: [menu_item_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order                 Order            @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  productVoucher        Voucher?         @relation(fields: [product_voucher_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  milkType              MilkType?        @relation(fields: [selected_milk_type_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  selectedPowder        MatchaPowder?    @relation(fields: [selected_powder_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([order_id], map: "idx_order_items_order_id")
  @@map("order_items")
}

model OrderItemAddon {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_item_id   String      @db.Uuid
  addon_option_id String      @db.Uuid
  quantity        Int
  unit_price_vnd  Int
  addonOption     AddonOption @relation(fields: [addon_option_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderItem       OrderItem   @relation(fields: [order_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("order_item_addons")
}

// ── New Phase 2 models ────────────────────────────────────────────────────────

model MatchaPowder {
  id                      String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                    String
  manufacturer            String?
  description             String?
  price_per_gram          Int
  type                    PowderType            @default(NONE)
  /// FK → menu_items; SET NULL on soft-delete. Used as Premium_Latte pricing anchor.
  reference_latte_item_id String?               @unique @db.Uuid
  fragrance               Int?
  body                    Int?
  bitterness              Int?
  umami                   Int?
  color                   Int?
  is_available            Boolean               @default(true)
  created_at              DateTime              @default(now()) @db.Timestamptz(6)
  fusionAllowedPowders    FusionAllowedPowder[]
  referenceLatteItem      MenuItem?             @relation("MatchaPowder_referenceLatteItem", fields: [reference_latte_item_id], references: [id], onUpdate: NoAction)
  defaultPowderItems      MenuItem[]            @relation("MenuItem_defaultPowder")
  matchaPowderItems       MenuItem[]            @relation("MenuItem_matchaPowder")
  orderItems              OrderItem[]
  powderSizeConfigs       PowderSizeConfig[]

  @@map("matcha_powder")
}

model MilkType {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  price_per_ml  Int
  is_default    Boolean     @default(false)
  is_active     Boolean     @default(true)
  display_order Int         @default(0)
  created_at    DateTime    @default(now()) @db.Timestamptz(6)
  orderItems    OrderItem[]

  @@map("milk_type")
}

/// System-wide size fallback. Always exactly 3 rows (M, L, XL). Admin-editable.
model DefaultSizeConfig {
  size        Size    @id
  milk_ml     Int
  powder_gram Decimal @db.Decimal

  @@map("default_size_config")
}

/// Per-powder gram exceptions. Only powders that differ from default_size_config have rows here.
model PowderSizeConfig {
  powder_id    String       @db.Uuid
  size         Size
  grams        Decimal      @db.Decimal
  matchaPowder MatchaPowder @relation(fields: [powder_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([powder_id, size])
  @@map("powder_size_config")
}

/// Which powders can be swapped on a Fusion item. Empty = only default powder, swap UI hidden.
model FusionAllowedPowder {
  menu_item_id String       @db.Uuid
  powder_id    String       @db.Uuid
  menuItem     MenuItem     @relation(fields: [menu_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  matchaPowder MatchaPowder @relation(fields: [powder_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([menu_item_id, powder_id])
  @@map("fusion_allowed_powder")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  STAFF
  ADMIN
}

enum VoucherType {
  DISCOUNT
  PRODUCT
}

enum DiscountType {
  PERCENT
  FIXED
}

enum VoucherStatus {
  ACTIVE
  REDEEMED
  EXPIRED
}

enum UsedChannel {
  ONLINE
  OFFLINE
}

enum OrderStatus {
  PENDING
  CONFIRMED
  READY
  COMPLETED
  CANCELLED
}

enum AddonType {
  SELECTOR
  TOGGLE
  QUANTITY
}

enum SweetnessLevel {
  NONE
  QUARTER
  HALF
  THREE_QUARTER
  FULL
}

enum Size {
  M
  L
  XL
}

enum IceOption {
  NORMAL
  LESS_ICE
  NO_ICE
  SEPARATE_ICE
}

enum PowderType {
  RECOMMEND
  NEW
  SEASONAL
  NONE
}
